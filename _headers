# Security headers — active on Netlify, ignored on GitHub Pages.
# If you migrate off GitHub Pages, these headers activate automatically.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; style-src 'self'; font-src 'self'; script-src 'self'; img-src 'self';
